<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nomad Studio — Premium CGI & AI Visual Production</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Space+Mono:wght@400;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;1,9..40,300&display=swap" rel="stylesheet">

<style>
  :root {
    --ink: #0e0d0b;
    --paper: #f5f2ec;
    --dust: #c8b89a;
    --rust: #b84b2a;
    --sand: #e8e0d0;
    --grey: #6b6560;
    --charcoal: #2a2520;
    --cream: #faf8f4;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--ink);
    color: var(--paper);
    overflow-x: hidden;
    font-size: 16px;
    line-height: 1.6;
  }

  /* ── CURSOR ── */
  .cursor {
    width: 8px; height: 8px;
    background: var(--rust);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9999;
    transform: translate(-50%, -50%);
    transition: transform 0.1s ease, width 0.3s ease, height 0.3s ease;
    mix-blend-mode: difference;
  }
  .cursor-ring {
    width: 36px; height: 36px;
    border: 1px solid rgba(200,184,154,0.4);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9998;
    transform: translate(-50%, -50%);
    transition: transform 0.18s ease, width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 28px 48px;
    display: flex; align-items: center; justify-content: space-between;
    mix-blend-mode: normal;
    transition: padding 0.4s ease;
  }
  nav.scrolled { padding: 18px 48px; background: rgba(14,13,11,0.85); backdrop-filter: blur(12px); }

  .nav-logo {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--paper);
    text-decoration: none;
  }
  .nav-logo span { color: var(--rust); }

  .nav-links {
    display: flex; gap: 40px; list-style: none;
  }
  .nav-links a {
    font-family: 'Space Mono', monospace;
    font-size: 11px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--dust);
    text-decoration: none;
    transition: color 0.3s ease;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute; bottom: -2px; left: 0; right: 0;
    height: 1px; background: var(--rust);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s ease;
  }
  .nav-links a:hover { color: var(--paper); }
  .nav-links a:hover::after { transform: scaleX(1); }

  .nav-cta {
    font-family: 'Space Mono', monospace;
    font-size: 11px; letter-spacing: 0.12em;
    text-transform: uppercase;
    background: var(--rust); color: var(--paper);
    border: none; padding: 10px 22px;
    cursor: pointer; text-decoration: none;
    transition: background 0.3s ease, transform 0.2s ease;
    display: inline-block;
  }
  .nav-cta:hover { background: #9a3d22; transform: translateY(-1px); }

  /* ── HERO ── */
  #hero {
    min-height: 100vh;
    display: grid;
    grid-template-rows: 1fr auto;
    padding: 0 48px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 70% 40%, rgba(184,75,42,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 20% 80%, rgba(200,184,154,0.05) 0%, transparent 50%);
  }

  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(200,184,154,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,184,154,0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 120px;
    position: relative;
    z-index: 2;
    max-width: 900px;
  }

  .hero-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 11px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--rust);
    margin-bottom: 32px;
    display: flex; align-items: center; gap: 16px;
    opacity: 0; animation: fadeUp 0.8s ease 0.2s forwards;
  }
  .hero-eyebrow::before {
    content: ''; width: 32px; height: 1px; background: var(--rust);
  }

  .hero-headline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(56px, 8vw, 110px);
    font-weight: 300;
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--paper);
    margin-bottom: 40px;
  }
  .hero-headline em {
    font-style: italic;
    color: var(--dust);
  }
  .hero-headline .accent { color: var(--rust); }

  .hero-headline .line { overflow: hidden; }
  .hero-headline .line span {
    display: block;
    opacity: 0;
    transform: translateY(100%);
    animation: slideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-headline .line:nth-child(1) span { animation-delay: 0.3s; }
  .hero-headline .line:nth-child(2) span { animation-delay: 0.45s; }
  .hero-headline .line:nth-child(3) span { animation-delay: 0.6s; }

  .hero-sub {
    font-size: 17px; font-weight: 300;
    color: var(--grey); line-height: 1.7;
    max-width: 480px;
    margin-bottom: 56px;
    opacity: 0; animation: fadeUp 0.8s ease 0.85s forwards;
  }

  .hero-actions {
    display: flex; gap: 20px; align-items: center;
    opacity: 0; animation: fadeUp 0.8s ease 1s forwards;
  }

  .btn-primary {
    font-family: 'Space Mono', monospace;
    font-size: 11px; letter-spacing: 0.15em;
    text-transform: uppercase;
    background: var(--rust); color: var(--paper);
    padding: 16px 36px; text-decoration: none;
    display: inline-block;
    transition: background 0.3s ease, transform 0.2s ease;
    position: relative; overflow: hidden;
  }
  .btn-primary::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(255,255,255,0.1);
    transform: translateX(-100%);
    transition: transform 0.4s ease;
  }
  .btn-primary:hover::after { transform: translateX(0); }
  .btn-primary:hover { transform: translateY(-2px); }

  .btn-secondary {
    font-family: 'Space Mono', monospace;
    font-size: 11px; letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dust); text-decoration: none;
    display: flex; align-items: center; gap: 8px;
    transition: color 0.3s ease;
  }
  .btn-secondary svg { transition: transform 0.3s ease; }
  .btn-secondary:hover { color: var(--paper); }
  .btn-secondary:hover svg { transform: translateX(4px); }

  .hero-bottom {
    padding-bottom: 48px;
    display: flex; justify-content: space-between; align-items: flex-end;
    position: relative; z-index: 2;
    border-top: 1px solid rgba(200,184,154,0.1);
    padding-top: 24px;
    opacity: 0; animation: fadeUp 0.8s ease 1.2s forwards;
  }

  .hero-stat {
    text-align: center;
  }
  .hero-stat .num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 42px; font-weight: 300;
    color: var(--paper); line-height: 1;
  }
  .hero-stat .label {
    font-family: 'Space Mono', monospace;
    font-size: 10px; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--grey);
    margin-top: 6px;
  }

  .hero-scroll {
    display: flex; flex-direction: column; align-items: center; gap: 8px;
  }
  .hero-scroll span {
    font-family: 'Space Mono', monospace;
    font-size: 10px; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--grey);
    writing-mode: vertical-rl;
  }
  .scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(to bottom, var(--rust), transparent);
    animation: scrollPulse 2s ease infinite;
  }

  /* ── MARQUEE ── */
  .marquee-section {
    border-top: 1px solid rgba(200,184,154,0.1);
    border-bottom: 1px solid rgba(200,184,154,0.1);
    padding: 18px 0;
    overflow: hidden;
    background: rgba(200,184,154,0.03);
  }
  .marquee-track {
    display: flex; gap: 0;
    animation: marquee 28s linear infinite;
    width: max-content;
  }
  .marquee-item {
    display: flex; align-items: center; gap: 48px;
    padding: 0 48px;
    font-family: 'Space Mono', monospace;
    font-size: 11px; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--grey);
    white-space: nowrap;
  }
  .marquee-item .dot {
    width: 4px; height: 4px;
    background: var(--rust); border-radius: 50%;
  }

  /* ── SECTIONS ── */
  section { padding: 120px 48px; }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--rust);
    margin-bottom: 24px;
    display: flex; align-items: center; gap: 16px;
  }
  .section-label::before {
    content: ''; width: 24px; height: 1px; background: var(--rust);
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(38px, 5vw, 64px);
    font-weight: 300; line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--paper);
    margin-bottom: 24px;
  }
  .section-title em { font-style: italic; color: var(--dust); }

  /* ── ABOUT ── */
  #about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
  }

  .about-visual {
    position: relative;
    aspect-ratio: 3/4;
    background: var(--charcoal);
    overflow: hidden;
  }

  .about-visual-inner {
    position: absolute; inset: 0;
    background:
      linear-gradient(135deg, rgba(184,75,42,0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 30% 70%, rgba(200,184,154,0.1) 0%, transparent 60%);
    display: flex; align-items: center; justify-content: center;
  }

  .about-visual-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 120px; font-weight: 300;
    color: rgba(200,184,154,0.06);
    letter-spacing: -0.05em;
    line-height: 1;
    text-align: center;
    user-select: none;
  }

  .about-visual-label {
    position: absolute; bottom: 24px; left: 24px;
    font-family: 'Space Mono', monospace;
    font-size: 10px; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--dust);
  }

  .about-visual-accent {
    position: absolute; top: 0; left: 0;
    width: 3px; height: 80px;
    background: var(--rust);
  }

  .about-text .section-title { margin-bottom: 32px; }

  .about-body {
    font-size: 16px; font-weight: 300;
    color: var(--grey); line-height: 1.8;
    margin-bottom: 24px;
  }

  .about-list {
    list-style: none;
    margin: 40px 0;
    display: flex; flex-direction: column; gap: 16px;
  }
  .about-list li {
    display: flex; align-items: center; gap: 16px;
    font-family: 'Space Mono', monospace;
    font-size: 12px; letter-spacing: 0.08em;
    color: var(--dust);
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(200,184,154,0.08);
  }
  .about-list li::before {
    content: '→';
    color: var(--rust); flex-shrink: 0;
  }

  /* ── WORK / SERVICES ── */
  #services {
    background: var(--charcoal);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-top: 80px;
    background: rgba(200,184,154,0.08);
  }

  .service-card {
    background: var(--charcoal);
    padding: 48px 40px;
    position: relative;
    overflow: hidden;
    transition: background 0.4s ease;
    cursor: default;
  }
  .service-card::before {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 3px; height: 0;
    background: var(--rust);
    transition: height 0.4s ease;
  }
  .service-card:hover { background: #1e1b18; }
  .service-card:hover::before { height: 100%; }

  .service-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 64px; font-weight: 300;
    color: rgba(200,184,154,0.06);
    line-height: 1;
    margin-bottom: 24px;
    transition: color 0.4s ease;
  }
  .service-card:hover .service-num { color: rgba(184,75,42,0.15); }

  .service-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px; font-weight: 400;
    color: var(--paper);
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .service-desc {
    font-size: 14px; font-weight: 300;
    color: var(--grey); line-height: 1.7;
    margin-bottom: 32px;
  }

  .service-tags {
    display: flex; flex-wrap: wrap; gap: 8px;
  }
  .service-tag {
    font-family: 'Space Mono', monospace;
    font-size: 9px; letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dust);
    border: 1px solid rgba(200,184,154,0.2);
    padding: 4px 10px;
  }

  /* ── PROCESS ── */
  #process {
    background: var(--ink);
  }

  .process-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: end;
    margin-bottom: 80px;
  }

  .process-intro {
    font-size: 16px; font-weight: 300;
    color: var(--grey); line-height: 1.8;
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }
  .process-steps::after {
    content: '';
    position: absolute; top: 32px; left: 10%; right: 10%;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(200,184,154,0.2), rgba(200,184,154,0.2), transparent);
  }

  .process-step {
    padding: 0 24px 0 0;
    position: relative; z-index: 2;
  }

  .step-dot {
    width: 64px; height: 64px;
    border: 1px solid rgba(200,184,154,0.15);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 32px;
    background: var(--ink);
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .process-step:hover .step-dot {
    border-color: var(--rust);
    background: rgba(184,75,42,0.08);
  }

  .step-dot span {
    font-family: 'Space Mono', monospace;
    font-size: 11px; letter-spacing: 0.1em;
    color: var(--dust);
  }

  .step-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 400;
    color: var(--paper);
    margin-bottom: 12px;
  }

  .step-body {
    font-size: 13px; font-weight: 300;
    color: var(--grey); line-height: 1.7;
  }

  /* ── WORK SHOWCASE ── */
  #work {
    background: var(--charcoal);
  }

  .work-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 64px;
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 2px;
  }

  .work-item {
    position: relative;
    overflow: hidden;
    background: #1a1715;
    cursor: pointer;
  }
  .work-item:nth-child(1) { grid-row: span 2; aspect-ratio: 3/4; }
  .work-item:nth-child(2), .work-item:nth-child(3) { aspect-ratio: 16/9; }

  .work-visual {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .work-item:hover .work-visual { transform: scale(1.04); }

  .work-visual-bg {
    position: absolute; inset: 0;
    transition: opacity 0.4s ease;
  }
  .work-item:nth-child(1) .work-visual-bg {
    background:
      radial-gradient(ellipse at 30% 40%, rgba(184,75,42,0.3) 0%, transparent 50%),
      linear-gradient(180deg, rgba(14,13,11,0) 40%, rgba(14,13,11,0.8) 100%);
  }
  .work-item:nth-child(2) .work-visual-bg {
    background:
      radial-gradient(ellipse at 70% 50%, rgba(200,184,154,0.15) 0%, transparent 60%),
      linear-gradient(180deg, rgba(14,13,11,0) 40%, rgba(14,13,11,0.8) 100%);
  }
  .work-item:nth-child(3) .work-visual-bg {
    background:
      radial-gradient(ellipse at 30% 50%, rgba(42,37,32,0.8) 0%, rgba(14,13,11,0.4) 100%),
      linear-gradient(180deg, rgba(14,13,11,0) 40%, rgba(14,13,11,0.8) 100%);
  }

  .work-glyph {
    font-family: 'Cormorant Garamond', serif;
    font-size: 180px; font-weight: 300;
    color: rgba(200,184,154,0.05);
    line-height: 1;
    user-select: none;
    transition: color 0.4s ease;
  }
  .work-item:hover .work-glyph { color: rgba(200,184,154,0.08); }

  .work-info {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 32px;
    background: linear-gradient(to top, rgba(14,13,11,0.9) 0%, transparent 100%);
    transform: translateY(8px); opacity: 0;
    transition: transform 0.4s ease, opacity 0.4s ease;
  }
  .work-item:hover .work-info { transform: translateY(0); opacity: 1; }

  .work-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 400;
    color: var(--paper); margin-bottom: 6px;
  }
  .work-category {
    font-family: 'Space Mono', monospace;
    font-size: 10px; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--rust);
  }

  /* ── RETAINER OFFER ── */
  #retainer {
    background: var(--ink);
    position: relative; overflow: hidden;
  }

  .retainer-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 50% 50%, rgba(184,75,42,0.07) 0%, transparent 70%);
  }

  .retainer-inner {
    position: relative; z-index: 2;
    max-width: 900px; margin: 0 auto;
    text-align: center;
  }

  .retainer-inner .section-label {
    justify-content: center;
  }
  .retainer-inner .section-label::before { display: none; }

  .retainer-inner .section-title { margin-bottom: 24px; }

  .retainer-body {
    font-size: 17px; font-weight: 300;
    color: var(--grey); line-height: 1.8;
    margin-bottom: 64px;
  }

  .retainer-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px; margin-bottom: 64px;
    background: rgba(200,184,154,0.08);
  }

  .retainer-card {
    background: var(--ink);
    padding: 40px 32px;
    text-align: left;
    position: relative;
    transition: background 0.3s ease;
  }
  .retainer-card.featured {
    background: var(--charcoal);
  }
  .retainer-card.featured::before {
    content: 'Most Popular';
    position: absolute; top: -1px; left: 50%; transform: translateX(-50%);
    font-family: 'Space Mono', monospace;
    font-size: 9px; letter-spacing: 0.15em;
    text-transform: uppercase;
    background: var(--rust); color: var(--paper);
    padding: 4px 16px;
    white-space: nowrap;
  }

  .retainer-tier {
    font-family: 'Space Mono', monospace;
    font-size: 10px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--rust);
    margin-bottom: 16px;
  }

  .retainer-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px; font-weight: 300;
    color: var(--paper); line-height: 1;
    margin-bottom: 8px;
  }
  .retainer-price sup {
    font-size: 24px; vertical-align: super;
  }
  .retainer-period {
    font-family: 'Space Mono', monospace;
    font-size: 10px; letter-spacing: 0.1em;
    color: var(--grey); margin-bottom: 32px;
  }

  .retainer-features {
    list-style: none;
    display: flex; flex-direction: column; gap: 12px;
    margin-bottom: 40px;
  }
  .retainer-features li {
    font-size: 13px; font-weight: 300;
    color: var(--dust); line-height: 1.5;
    display: flex; align-items: flex-start; gap: 10px;
  }
  .retainer-features li::before {
    content: '—'; color: var(--rust);
    flex-shrink: 0; margin-top: 0;
  }

  /* ── CONTACT ── */
  #contact {
    background: var(--charcoal);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: start;
  }

  .contact-info p {
    font-size: 16px; font-weight: 300;
    color: var(--grey); line-height: 1.8;
    margin-bottom: 48px;
  }

  .contact-details {
    display: flex; flex-direction: column; gap: 24px;
  }

  .contact-detail {
    display: flex; flex-direction: column; gap: 4px;
  }
  .contact-detail-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--rust);
  }
  .contact-detail-value {
    font-size: 16px; font-weight: 300;
    color: var(--paper);
  }

  .contact-form {
    display: flex; flex-direction: column; gap: 24px;
  }

  .form-group {
